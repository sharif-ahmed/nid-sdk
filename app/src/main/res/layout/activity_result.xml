<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kyc_background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="36dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Verification Result"
            android:textColor="@color/white"
            android:textSize="20sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Result Status Icon -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_image_placeholder">

                <ImageView
                    android:id="@+id/imgStatusIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/kyc_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="Matched"
                android:visibility="gone"
                android:textColor="@color/kyc_text_primary"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/statusDescText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:visibility="gone"
                android:text="@string/kyc_result_match_desc"
                android:textColor="@color/kyc_text_hint"
                android:textSize="14sp" />

            <!-- Selfie Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="160dp"
                android:layout_height="200dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/kyc_card_bg"
                app:cardCornerRadius="80dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/kyc_primary"
                app:strokeWidth="2dp">

                <ImageView
                    android:id="@+id/imgResultSelfie"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Info Container -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/kyc_card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/kyc_result_details_title"
                        android:textColor="@color/kyc_primary"
                        android:textSize="16sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"/>
                    <!-- Match Code -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/kyc_result_code_label"
                            android:textColor="@color/kyc_text_hint" />
                        <TextView
                            android:id="@+id/tvResultCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/kyc_text_primary"
                            android:text="0.95" />
                    </LinearLayout>

                    <!-- Match Score -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/kyc_result_score_label"
                            android:textColor="@color/kyc_text_hint" />
                        <TextView
                            android:id="@+id/tvResultScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/kyc_text_primary"
                            android:text="0.95" />
                    </LinearLayout>

                    <!-- Full Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Full Name"
                            android:textColor="@color/kyc_text_hint" />
                        <TextView
                            android:id="@+id/tvResultName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/kyc_text_primary"
                            android:text="John Doe" />
                    </LinearLayout>

                    <!-- NID Number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NID Number"
                            android:textColor="@color/kyc_text_hint" />
                        <TextView
                            android:id="@+id/tvResultNid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/kyc_text_primary"
                            android:text="1234567890" />
                    </LinearLayout>

                    <!-- DOB -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Date of Birth"
                            android:textColor="@color/kyc_text_hint" />
                        <TextView
                            android:id="@+id/tvResultDob"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/kyc_text_primary"
                            android:text="01/01/1990" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/doneButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/nid_done"
                android:textSize="16sp"
                app:backgroundTint="@color/kyc_primary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
