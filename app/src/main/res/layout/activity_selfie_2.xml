<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Face Oval Overlay -->
    <!--<View
        android:layout_width="260dp"
        android:layout_height="340dp"
        android:layout_centerInParent="true"
        android:background="@drawable/face_oval_guide" />-->
    <com.commlink.citl_nid_sdk.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Position your face in the oval"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Liveness Progress Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Blink Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eye Blink"
                android:textColor="#FFF" />
            <ProgressBar
                android:id="@+id/pbBlink"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_toLeftOf="@id/imgBlinkCheck"
                android:layout_marginRight="10dp" />
            <ImageView
                android:id="@+id/imgBlinkCheck"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_check_circle"
                android:visibility="invisible" />
        </RelativeLayout>

        <!-- Smile Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smile"
                android:textColor="#FFF" />
            <ProgressBar
                android:id="@+id/pbSmile"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_toLeftOf="@id/imgSmileCheck"
                android:layout_marginRight="10dp" />
            <ImageView
                android:id="@+id/imgSmileCheck"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_check_circle"
                android:visibility="invisible" />
        </RelativeLayout>

        <!-- Turn Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Head Turn"
                android:textColor="#FFF" />
            <ProgressBar
                android:id="@+id/pbTurn"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_toLeftOf="@id/imgTurnCheck"
                android:layout_marginRight="10dp" />
            <ImageView
                android:id="@+id/imgTurnCheck"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_check_circle"
                android:visibility="invisible" />
        </RelativeLayout>

        <ImageButton
            android:id="@+id/captureButton"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="10dp"
            android:background="@drawable/nid_capture_button_bg"
            android:contentDescription="@string/nid_selfie_capture"
            android:enabled="true" />

    </LinearLayout>
</RelativeLayout>
